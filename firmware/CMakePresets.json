{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {}
        },
        {
            "name": "debug",
            "hidden": true,
            "inherits": [
                "default"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "hidden": true,
            "inherits": [
                "default"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "app-hello",
            "hidden": true,
            "cacheVariables": {
                "TARGET_APP": "hello_world"
            }
        },
        {
            "name": "hello-debug",
            "displayName": "Hello World (Debug)",
            "inherits": [
                "debug",
                "app-hello"
            ]
        },
        {
            "name": "hello-release",
            "displayName": "Hello World (Release)",
            "inherits": [
                "release",
                "app-hello"
            ]
        },
        {
            "name": "app-vca-test",
            "hidden": true,
            "cacheVariables": {
                "TARGET_APP": "vca_test"
            }
        },
        {
            "name": "vca-test-debug",
            "displayName": "VCA Test (Debug)",
            "inherits": [
                "debug",
                "app-vca-test"
            ]
        },
        {
            "name": "vca-test-release",
            "displayName": "VCA Test (Release)",
            "inherits": [
                "release",
                "app-vca-test"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "hello-debug",
            "configurePreset": "hello-debug"
        },
        {
            "name": "hello-release",
            "configurePreset": "hello-release"
        },
        {
            "name": "vca-test-debug",
            "configurePreset": "vca-test-debug"
        },
        {
            "name": "vca-test-release",
            "configurePreset": "vca-test-release"
        }
    ]
}