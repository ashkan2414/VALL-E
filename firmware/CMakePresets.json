{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {}
        },
        {
            "name": "app-hello",
            "hidden": true,
            "cacheVariables": {
                "TARGET_APP": "hello_world"
            }
        },
        {
            "name": "Hello-Debug",
            "displayName": "Hello World (Debug)",
            "inherits": [
                "default",
                "app-hello"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Hello-Release",
            "displayName": "Hello World (Release)",
            "inherits": [
                "default",
                "app-hello"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Hello-Debug",
            "configurePreset": "Hello-Debug"
        },
        {
            "name": "Hello-Release",
            "configurePreset": "Hello-Release"
        }
    ]
}