Checks: >
  readability-*,
  bugprone-*,
  clang-analyzer-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-using,
  modernize-redundant-void-arg,
  modernize-use-default-member-init,
  cppcoreguidelines-narrowing-conversions,
  cppcoreguidelines-init-variables,
  cppcoreguidelines-no-malloc,
  cppcoreguidelines-pro-type-member-init,
  hicpp-signed-bitwise,
  hicpp-no-assembler,
  hicpp-explicit-conversions,
  performance-unnecessary-value-param,
  performance-for-range-copy,
  -readability-convert-member-functions-to-static
  -bugprone-easily-swappable-parameters

WarningsAsErrors: >
  bugprone-*,
  clang-analyzer-*
  readability-identifier-naming

CheckOptions:
  # -------------------------------------------------------------------------
  # Variables (General)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.VariableCase
    value:           lower_case

  # -------------------------------------------------------------------------
  # Member Variables (m_)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.MemberVariableCase
    value:           lower_case
  - key:             readability-identifier-naming.MemberVariablePrefix
    value:           m_

  # -------------------------------------------------------------------------
  # Member Pointers (mp_)
  # -------------------------------------------------------------------------
  # "MemberPointer" specific check
  - key:             readability-identifier-naming.MemberPointerCase
    value:           lower_case
  - key:             readability-identifier-naming.MemberPointerPrefix
    value:           mp_

  # -------------------------------------------------------------------------
  # Global Variables (g_)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.GlobalVariableCase
    value:           lower_case
  - key:             readability-identifier-naming.GlobalVariablePrefix
    value:           g_

  # -------------------------------------------------------------------------
  # Global Pointers (gp_)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.GlobalPointerCase
    value:           lower_case
  - key:             readability-identifier-naming.GlobalPointerPrefix
    value:           gp_

  # -------------------------------------------------------------------------
  # Constants (k)
  # -------------------------------------------------------------------------
  # "ConstVariable" covers local constants
  - key:             readability-identifier-naming.ConstVariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.ConstVariablePrefix
    value:           k

  # -------------------------------------------------------------------------
  # Constant Pointers (kp)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.ConstPointerCase
    value:           CamelCase
  - key:             readability-identifier-naming.ConstPointerPrefix
    value:           kp

  # -------------------------------------------------------------------------
  # Global Constants (k)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.GlobalConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalConstantPrefix
    value:           k
  # -------------------------------------------------------------------------
  # Global Constant Pointers (gkp)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.GlobalConstantPointerCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalConstantPointerPrefix
    value:           gkp

  # -------------------------------------------------------------------------
  # Static Member Constants (sk)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.ClassConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.ClassConstantPrefix
    value:           sk
  - key:             readability-identifier-naming.ClassConstantIgnoredRegexp
    value:           value

  # -------------------------------------------------------------------------
  # Static Member Constexpr (sk)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.ClassConstexprCase
    value:           CamelCase
  - key:             readability-identifier-naming.ClassConstexprPrefix
    value:           sk
  - key:             readability-identifier-naming.ClassConstexprIgnoredRegexp
    value:           value

  # -------------------------------------------------------------------------
  # Functions (lower_case)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.FunctionCase
    value:           lower_case

  # -------------------------------------------------------------------------
  # Types (Classes, Structs, Enums)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.ClassCase
    value:           CamelCase
  - key:             readability-identifier-naming.StructCase
    value:           CamelCase
  - key:             readability-identifier-naming.EnumCase
    value:           CamelCase
  - key:             readability-identifier-naming.UnionCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypedefCase
    value:           CamelCase

  # -------------------------------------------------------------------------
  # Enum Constants (k)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.EnumConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.EnumConstantPrefix
    value:           k

  # -------------------------------------------------------------------------
  # Templates (T, tk)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.TypeTemplateParameterPrefixCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypeTemplateParameterPrefixPrefix
    value:           T
  - key:             readability-identifier-naming.ValueTemplateParameterPrefixCase
    value:           CamelCase
  - key:             readability-identifier-naming.ValueTemplateParameterPrefixPrefix
    value:           tk

  # -------------------------------------------------------------------------
  # Macros (UPPER_CASE)
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.MacroDefinitionCase
    value:           UPPER_CASE

  # -------------------------------------------------------------------------
  # Concepts
  # -------------------------------------------------------------------------
  - key:             readability-identifier-naming.ConceptCase
    value:           CamelCase
  - key:             readability-identifier-naming.ConceptPrefix
    value:           C

  # -------------------------------------------------------------------------
  # Magic Numbers
  # -------------------------------------------------------------------------
  - key:             readability-magic-numbers.IgnoredIntegerValues
    value:           '-1;0;1;2;3;4;5;10;100;180;360'
  - key:             readability-magic-numbers.IgnoredFloatingPointValues
    value:           '-1.0;0.0;1.0;180.0;360.0'

  # -------------------------------------------------------------------------
  # Identifier Lengths
  # -------------------------------------------------------------------------
  - key:             readability-identifier-length.IgnoredVariableNames
    value:           '^[njcxy]$'
  - key:             readability-identifier-length.IgnoredParameterNames
    value:           '^[njcxy]$'