{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash (ST-Link)",
            "type": "shell",
            "command": "STM32_Programmer_CLI.exe",
            "args": [
                "-c",
                "port=SWD",
                "-w",
                "${command:cmake.launchTargetPath}",
                "-v",
                "-rst"
            ],
            "dependsOn": "CMake: build",
            "problemMatcher": []
        },
        {
            "label": "Build All Presets",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/ci/build_all_presets.py"
            ],
            "problemMatcher": []
        }
    ]
}